# Copy this file to .env or node.env (in this folder or project root) and fill in values.

# --- Option A: MongoDB Atlas (cloud) ---
# Get the connection string from Atlas: Cluster -> Connect -> Connect your application
# Replace <password> with your database user password. Use correct username and database name.
# MONGODB_URI=mongodb+srv://USERNAME:<password>@cluster0.xxxxx.mongodb.net/autofinder?retryWrites=true&w=majority

# --- Option B: Local MongoDB (no Atlas auth) ---
# If you have MongoDB installed locally and want to skip Atlas auth errors:
# USE_LOCAL_MONGO=1
# Optional: custom local URI (default is mongodb://127.0.0.1:27017/autofinder)
# LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/autofinder

# --- JWT (required for login) ---
# JWT_SECRET_KEY=your-long-random-secret-at-least-32-characters

# --- Server port (optional, default 8001) ---
# PORT=8001

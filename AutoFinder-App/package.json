{
  "name": "autofinder",
  "version": "1.0.0",
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 EXPO_DEVTOOLS_LISTEN_ADDRESS=0.0.0.0 expo start --tunnel --clear --host tunnel",
    "start:lan": "cross-env NODE_OPTIONS=--max-old-space-size=4096 EXPO_DEVTOOLS_LISTEN_ADDRESS=0.0.0.0 expo start --lan --clear",
    "start:ip": "cross-env NODE_OPTIONS=--max-old-space-size=4096 EXPO_DEVTOOLS_LISTEN_ADDRESS=192.168.100.6 expo start --host 192.168.100.6 --port 8081 --clear",
    "start:tunnel": "cross-env NODE_OPTIONS=--max-old-space-size=4096 expo start --tunnel --clear --host tunnel",
    "start:localhost": "cross-env NODE_OPTIONS=--max-old-space-size=4096 expo start --clear",
    "android": "cross-env NODE_OPTIONS=--max-old-space-size=4096 expo run:android",
    "ios": "cross-env NODE_OPTIONS=--max-old-space-size=4096 expo run:ios",
    "web": "cross-env NODE_OPTIONS=--max-old-space-size=4096 expo start --web",
    "ts:check": "tsc",
    "build:android:apk": "eas build --platform android --profile preview",
    "build:android:apk:prod": "eas build --platform android --profile production",
    "build:android:aab": "eas build --platform android --profile production",
    "submit:android": "eas submit --platform android",
    "build:ios:preview": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "build:ios": "eas build --platform ios --profile preview",
    "submit:ios": "eas submit --platform ios",
    "postinstall-disabled": "node fix-packages.js && node fix-vector-icons.js && node fix-image-viewing.js && node fix-multi-slider.js && node fix-circular-progress.js && node fix-linear-gradient.js && node fix-swiper.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@ptomasroos/react-native-multi-slider": "^2.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@react-navigation/stack": "^6.3.29",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-in-app-purchases": "^14.5.0",
    "expo-linear-gradient": "15.0.8",
    "expo-location": "~19.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^6.0.9",
    "expo-web-browser": "~15.0.10",
    "lottie-react-native": "^7.2.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1313.0",
    "react-native-circular-progress": "^1.4.1",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-dropdown-picker": "^5.4.6",
    "react-native-edge-to-edge": "^1.7.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-viewing": "^0.2.2",
    "react-native-maps": "1.20.1",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-multi-slider": "^0.3.6",
    "react-native-pager-view": "6.9.1",
    "react-native-radio-buttons-group": "^3.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-slider": "^0.11.0",
    "react-native-svg": "15.12.1",
    "react-native-swiper": "^1.6.0",
    "react-native-tab-view": "^4.0.8",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "metro-react-native-babel-transformer": "^0.77.0",
    "@babel/plugin-transform-class-properties": "^7.25.9",
    "@babel/plugin-transform-private-methods": "^7.25.9",
    "@babel/plugin-transform-private-property-in-object": "^7.27.1",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@types/react": "~19.1.10",
    "@typescript-eslint/parser": "^5.48.0",
    "cross-env": "^10.1.0",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}

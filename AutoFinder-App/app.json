{
  "expo": {
    "name": "AutoFinder",
    "slug": "autofinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "scheme": "autofinder",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adeel360.autofinder",
      "associatedDomains": [
        "applinks:autofinder.pk",
        "applinks:www.autofinder.pk",
        "applinks:autofinder.pk",
        "applinks:www.autofinder.pk"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#CD0100"
      },
      "icon": "./assets/icon.png",
      "package": "com.adeel360.autofinder",
      "versionCode": 2,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "autofinder.pk",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.autofinder.pk",
              "pathPrefix": "/"
            },
            {
              "scheme": "autofinder"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": []
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your listings.",
          "cameraPermission": "The app accesses your camera to let you take photos for your listings."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow AutoFinder to use your location to show nearby listings."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "28c4ae26-1cd4-4412-bf9d-350d7cee151c"
      }
    }
  }
}
